# Copy these into .env.local (local dev) AND into Vercel → Project → Settings →
# Environment Variables (production). Restart the dev server after editing.

# ---- Access (shared password) ----
# The single password you hand to people you want to have access.
SITE_PASSWORD=change-me-to-a-strong-password

# ---- Assistant (Anthropic) ----
ANTHROPIC_API_KEY=sk-ant-...
# Optional: faster/cheaper assistant model (default is claude-opus-4-8)
# ANTHROPIC_MODEL=claude-haiku-4-5
# Optional: model for the AUTOMATIC new-openings web scan (Vercel Cron, every
# 6h). Defaults to claude-haiku-4-5 (cheap + fast). Manual "Scan now" from the
# New openings page uses ANTHROPIC_MODEL instead.
# OPENINGS_SCAN_MODEL=claude-haiku-4-5

# ---- Google Places (restaurant enrichment) ----
# Used by scripts/fetch-fsa.mjs to enrich venues with phone, website and
# confirmed business status. Get a key at console.cloud.google.com and enable
# the "Places API (New)". Without this the script still runs but skips enrichment.
# Billed at ~$40/1000 requests (Contact field mask). Only used server-side / in scripts.
GOOGLE_PLACES_API_KEY=AIza...

# ---- Shared team database (Supabase) ----
# From Supabase → Project Settings → API. The SERVICE ROLE key is secret —
# server-only, never exposed to the browser. Leave these blank to run in
# per-browser localStorage mode instead.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Base dataset host (Supabase Storage) ----
# The ~20k FSA venues are hosted as a JSON blob in Supabase Storage so the weekly
# refresh (scripts/fetch-fsa.mjs, run by .github/workflows/fsa-refresh.yml) can
# update them without a redeploy. Set this to the blob's PUBLIC URL — the refresh
# script prints it after uploading. Leave blank to use the bundled
# public/uk-restaurants.json instead (fine for local dev).
# NEXT_PUBLIC_DATASET_URL=https://YOUR-PROJECT.supabase.co/storage/v1/object/public/datasets/uk-restaurants.json
# Optional: bucket name the refresh uploads to (default "datasets").
# DATASET_BUCKET=datasets
#
# For the weekly GitHub Actions refresh, add these as repo secrets (Settings →
# Secrets and variables → Actions): GOOGLE_PLACES_API_KEY, SUPABASE_URL,
# SUPABASE_SERVICE_ROLE_KEY. The workflow self-creates the (public) bucket.

# ---- Power BI customer sync ----
# Pulls the customer list from Power BI nightly and flags matching venues as
# existing customers in the shared DB. NOTE: Power BI has no plain "API key" —
# it uses Microsoft Entra ID (Azure AD) OAuth2. Ask your Power BI/Azure admin
# for the values below. Leave blank to disable the sync.
#
# WHAT TO ASK YOUR ADMIN FOR:
#   1. An Entra ID *app registration* (service principal) — recommended:
#        - Directory (tenant) ID, Application (client) ID, and a client secret
#        - Admin must enable "Service principals can use Power BI APIs" in the
#          Power BI admin portal, and add the app to the workspace (Member/Viewer)
#      OR, if a service principal isn't possible, a Power BI username + password
#      (no MFA) plus the client ID of a public app registration.
#   2. The Workspace (group) ID and Dataset ID that contain the customer list
#      (open the dataset in Power BI → the URL has /groups/<workspace>/datasets/<dataset>).
#   3. The table + column names for customer business name and postcode.
POWERBI_TENANT_ID=
POWERBI_CLIENT_ID=
# Service principal (recommended): set the secret.
POWERBI_CLIENT_SECRET=
# OR user account (only if a service principal isn't available; breaks with MFA):
# POWERBI_USERNAME=
# POWERBI_PASSWORD=
# Where the customer data lives:
POWERBI_WORKSPACE_ID=
POWERBI_DATASET_ID=
# How to read customers: either name the table + columns...
POWERBI_CUSTOMERS_TABLE=Customers
POWERBI_NAME_COLUMN=Name
POWERBI_POSTCODE_COLUMN=Postcode
# ...or override the whole DAX query (aliases MUST be "name" and "postcode"):
# POWERBI_CUSTOMERS_DAX=EVALUATE SELECTCOLUMNS('Customers', "name", 'Customers'[Name], "postcode", 'Customers'[Postcode])
#
# Optional: also sync account-contact fields into the mobile "Contact info"
# panel (nightly, same sync as above). Only added to the query if set — leave
# any of these blank to skip that field.
# POWERBI_CONTACT_NAME_COLUMN=ContactName
# POWERBI_CONTACT_PHONE_COLUMN=Phone
# POWERBI_CONTACT_EMAIL_COLUMN=Email
# POWERBI_ACCOUNT_MANAGER_COLUMN=AccountManager

# ---- Power BI sales report (mobile customer "Sales" panel) ----
# Embeds a real, interactive Power BI report ("app owns data": the SAME Entra
# service principal above mints a short-lived, view-only embed token per
# session server-side) — field staff need no Power BI licence or login of
# their own. Requires:
#   1. The service principal (POWERBI_CLIENT_ID above) added to the workspace
#      that contains the sales report (Member/Viewer), same as for the dataset.
#   2. The report's ID — open the report in Power BI Service, the URL has
#      /groups/<workspace>/reports/<reportId>.
POWERBI_SALES_REPORT_ID=
# Workspace the report lives in, if different from POWERBI_WORKSPACE_ID above.
# POWERBI_SALES_WORKSPACE_ID=
# Optional: scope the report to the tapped customer via a Power BI basic
# filter (Table + Column values below; the app filters where that column
# equals the customer's postcode). Leave blank to show the report unfiltered.
# POWERBI_SALES_FILTER_TABLE=Customers
# POWERBI_SALES_FILTER_COLUMN=Postcode

# ---- Contact-update requests (mobile customer "Contact" panel) ----
# Recipient for the "Email customer service" quick-action, used to flag wrong
# contact details for correction in Power BI. Read in the browser (NEXT_PUBLIC_)
# to build a mailto: link — same "open in your own mail app" pattern as the
# rest of the app (nothing is sent automatically). Leave blank to still show
# the button; the salesperson just has to fill in the recipient themselves.
NEXT_PUBLIC_CUSTOMER_SERVICE_EMAIL=

# ---- Cron protection ----
# A random secret. Vercel Cron sends it as `Authorization: Bearer <value>` so
# only the scheduler (or you, with the header) can trigger the sync.
CRON_SECRET=generate-a-long-random-string
